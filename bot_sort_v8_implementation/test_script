import cv2
from ultralytics import YOLO
from collections import defaultdict
import numpy as np
from cap_from_youtube import cap_from_youtube # Import the helper

# Load a pre-trained YOLO model (e.g., yolov8n.pt for the nano version)
# Other models like 'yolov8m.pt' (medium) or 'yolov8x.pt' (extra large) can also be used
model = YOLO('yolov8n.pt')

# Open the video source (YouTube URL or local file)
video_url = "https://www.youtube.com/watch?v=MNn9qKG2UFI" # A clear highway view
cap = cap_from_youtube(video_url, '720p')

# Store the track history
track_history = defaultdict(lambda: [])

while cap.isOpened():
    success, frame = cap.read()
    if not success:
        break

    # Run YOLOv8 tracking on the frame, persisting tracks between frames
    results = model.track(frame, persist=True, stream=True, tracker="tester.yaml")

    for r in results:
        annotated_frame = r.plot() # Draw the standard YOLO boxes
        
        if r.boxes.id is not None:
            boxes = r.boxes.xywh.cpu()
            track_ids = r.boxes.id.int().cpu().tolist()

            for box, track_id in zip(boxes, track_ids):
                x, y, w, h = box
                track = track_history[track_id]
                track.append((float(x), float(y)))
                if len(track) > 30:
                    track.pop(0)

                # Draw the breadcrumb trajectory
                if len(track) > 1:
                    points = np.array(track).astype(np.int32).reshape((-1, 1, 2))
                    cv2.polylines(annotated_frame, [points], isClosed=False, color=(0, 255, 0), thickness=2)

        cv2.imshow("YOLOv8 YouTube Tracking", annotated_frame)

    if cv2.waitKey(1) & 0xFF == ord("q"):
        break

cap.release()
cv2.destroyAllWindows()